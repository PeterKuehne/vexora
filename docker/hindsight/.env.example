# Hindsight Memory Server — Environment Variables
# Copy to .env and fill in your values

# PostgreSQL password (same as existing cor7ex DB user)
DB_PASSWORD=your_postgres_password

# OVH AI Endpoints (EU-Cloud, same as Cor7ex backend)
OVH_AI_BASE_URL=https://oai.endpoints.kepler.ai.cloud.ovh.net/v1
OVH_AI_API_KEY=your_ovh_api_key
OVH_AI_MODEL=gpt-oss-120b
