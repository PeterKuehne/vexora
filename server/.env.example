# ===========================================
# Cor7ex Backend - Environment Variables
# ===========================================
# Copy this file to .env for local development
# cp .env.example .env

# Port for the Express server
PORT=3001

# Node environment
NODE_ENV=development

# Ollama API URL
OLLAMA_API_URL=http://localhost:11434

# Default LLM model
OLLAMA_DEFAULT_MODEL=qwen3:8b

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# ===========================================
# Neo4j Graph Database (Phase 4)
# ===========================================
# Neo4j connection URI (Ubuntu Server)
NEO4J_URI=bolt://192.168.2.38:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=changeme
NEO4J_DATABASE=neo4j

# Enable/disable graph features
GRAPH_ENABLED=true
GRAPH_ENTITY_EXTRACTION=true
GRAPH_LLM_EXTRACTION=false

# ===========================================
# LLM Providers (Phase 1: Hive Mind)
# ===========================================
# Anthropic API Key (optional - enables Claude models)
# ANTHROPIC_API_KEY=sk-ant-...

# ===========================================
# PII Guard - Microsoft Presidio (Phase 1)
# ===========================================
# Enable/disable PII masking before cloud LLM calls
PII_GUARD_ENABLED=true

# Presidio service URLs (Ubuntu Server)
PRESIDIO_ANALYZER_URL=http://192.168.2.38:8003
PRESIDIO_ANONYMIZER_URL=http://192.168.2.38:8004

# Minimum confidence for PII detection (0.0-1.0)
PII_MIN_CONFIDENCE=0.7
